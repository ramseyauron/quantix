{
  "__inputs": [{"name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus"}],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""}
  ],
  "description": "Quantix Post-Quantum Blockchain — Node Monitoring",
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "id": 1, "title": "Block Height", "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "fieldConfig": {"defaults": {"unit": "short", "custom": {"lineWidth": 2, "fillOpacity": 10}}},
      "targets": [{"expr": "quantix_block_height", "legendFormat": "{{node}}", "refId": "A"}]
    },
    {
      "id": 2, "title": "TPS (Transactions Per Second)", "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "fieldConfig": {"defaults": {"unit": "reqps", "custom": {"lineWidth": 2, "fillOpacity": 10}}},
      "targets": [{"expr": "rate(quantix_transactions_total[1m])", "legendFormat": "{{node}}", "refId": "A"}]
    },
    {
      "id": 3, "title": "Mempool Size", "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 8},
      "fieldConfig": {"defaults": {"unit": "short", "custom": {"lineWidth": 2, "fillOpacity": 10}}},
      "targets": [{"expr": "quantix_mempool_size", "legendFormat": "{{node}}", "refId": "A"}]
    },
    {
      "id": 4, "title": "Peer Count", "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 8},
      "fieldConfig": {"defaults": {"unit": "short", "custom": {"lineWidth": 2, "fillOpacity": 10}}},
      "targets": [{"expr": "quantix_peer_count", "legendFormat": "{{node}}", "refId": "A"}]
    },
    {
      "id": 5, "title": "Active Validators", "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 8},
      "fieldConfig": {"defaults": {"unit": "short", "custom": {"lineWidth": 2, "fillOpacity": 10}}},
      "targets": [{"expr": "quantix_validator_count", "legendFormat": "{{node}}", "refId": "A"}]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["quantix", "blockchain", "post-quantum"],
  "templating": {"list": [
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "definition": "label_values(quantix_block_height, env)",
      "includeAll": true, "multi": true, "name": "env",
      "query": "label_values(quantix_block_height, env)", "refresh": 2, "type": "query", "label": "Environment"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "definition": "label_values(quantix_block_height, node)",
      "includeAll": true, "multi": true, "name": "node",
      "query": "label_values(quantix_block_height, node)", "refresh": 2, "type": "query", "label": "Node"
    }
  ]},
  "time": {"from": "now-1h", "to": "now"},
  "timezone": "browser",
  "title": "Quantix Node Dashboard",
  "uid": "quantix-nodes-v2",
  "version": 2
}
